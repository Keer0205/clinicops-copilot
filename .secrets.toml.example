# ClinicOps Copilot — Streamlit Secrets example
#
# HOW TO USE (local development):
#   1. Copy this file to .streamlit/secrets.toml
#   2. Fill in your real values below
#   3. Never commit .streamlit/secrets.toml to git (it is already in .gitignore)
#
# HOW TO USE (Streamlit Cloud):
#   Paste the key=value pairs into:
#   App → Settings → Secrets

# Required: your OpenAI API key
OPENAI_API_KEY = "sk-..."

# Optional: override the default models
# OPENAI_EMBED_MODEL = "text-embedding-3-small"
# OPENAI_CHAT_MODEL  = "gpt-4o-mini"

# Optional: prefill the demo URL on the Share Demo page
# APP_URL = "https://<your-app>.streamlit.app"
